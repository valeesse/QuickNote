{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "QuickNote",
  "version": "0.1.0",
  "identifier": "com.quicknote.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuickNote - 极速便签",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      },
      {
        "label": "clipboard-popup",
        "title": "剪贴板历史",
        "width": 400,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "url": "/clipboard-popup"
      },
      {
        "label": "quick-note",
        "title": "快速便签",
        "width": 500,
        "height": 400,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "url": "/quick-note"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/com.quicknote.desktop/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {}
}

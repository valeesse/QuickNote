{
  "name": "quicknote-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:desktop": "npm --prefix apps/desktop run dev",
    "build:desktop": "npm --prefix apps/desktop run build",
    "tauri": "npm --prefix apps/desktop run tauri --",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "test:e2e": "npm --prefix apps/desktop run test:e2e",
    "test:desktop-rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "test:server": "cargo test --manifest-path apps/server/Cargo.toml",
    "test:protocol": "cargo test --manifest-path crates/quicknote-protocol/Cargo.toml"
  }
}

{
  "compilerOptions": {
    "target": "ES2021",
    "useDefineForClassFields": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@ui/*": ["../../packages/ui/src/*"],
      "@contracts": ["../../packages/contracts/src"],
      "react": ["node_modules/@types/react"],
      "react/jsx-runtime": ["node_modules/@types/react/jsx-runtime"],
      "react/jsx-dev-runtime": ["node_modules/@types/react/jsx-dev-runtime"],
      "react-dom": ["node_modules/@types/react-dom"],
      "react-dom/*": ["node_modules/@types/react-dom/*"],
      "lucide-react": ["node_modules/lucide-react"],
      "yjs": ["node_modules/yjs"],
      "y-indexeddb": ["node_modules/y-indexeddb"],
      "y-protocols/*": ["node_modules/y-protocols/*"],
      "yjs/*": ["node_modules/yjs/*"],
      "@tiptap/core": ["node_modules/@tiptap/core"],
      "@tiptap/core/*": ["node_modules/@tiptap/core/*"],
      "@tiptap/*": ["node_modules/@tiptap/*"],
      "@tiptap/pm/*": ["node_modules/@tiptap/pm/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
